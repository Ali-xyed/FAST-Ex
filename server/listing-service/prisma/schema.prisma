generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  type        ListingType
  title       String
  description String
  imageUrl    String?
  isVerified  Boolean       @default(false)
  marked      MarkedStatus  @default(PENDING)
  createdAt   DateTime      @default(now())

  sellListing     SellListing?
  rentListing     RentListing?
  exchangeListing ExchangeListing?
  comments        Comment[]
}

model SellListing {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  listingId    String  @unique @db.ObjectId
  listing      Listing @relation(fields: [listingId], references: [id])
  price        Float
  isBargaining Boolean @default(true)
}

model RentListing {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  listingId    String  @unique @db.ObjectId
  listing      Listing @relation(fields: [listingId], references: [id])
  pricePerHour Float
  isBargaining Boolean @default(true)
}

model ExchangeListing {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  listingId       String  @unique @db.ObjectId
  listing         Listing @relation(fields: [listingId], references: [id])
  withTitle       String?
  withDescription String?
}

model Comment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  content    String
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])
  fromEmail  String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Bargain {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  listingId String        @db.ObjectId
  fromEmail String
  toEmail   String
  price     Float
  status    BargainStatus @default(PENDING)
  createdAt DateTime      @default(now())
}

model Exchange {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  listingId        String         @db.ObjectId
  fromEmail        String
  toEmail          String
  status           ExchangeStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  
  offerTitle       String
  offerDescription String
  offerImageUrl    String?
}

enum ListingType {
  SELL
  RENT
  EXCHANGE
}

enum MarkedStatus {
  PENDING
  SOLD
  RENTED
  EXCHANGED
}

enum BargainStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  DECLINED
}

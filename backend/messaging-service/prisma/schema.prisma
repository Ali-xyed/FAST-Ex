generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Chat {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  user1    String
  user2    String
  messages Message[]
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  chatId    String   @db.ObjectId
  chat      Chat     @relation(fields: [chatId], references: [id])
  content   String
  sender    String
  receiver  String
  createdAt DateTime @default(now())
}

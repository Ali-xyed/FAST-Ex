generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  type        ListingType
  title       String
  description String
  imageUrl    String?
  isVerified  Boolean       @default(false)
  marked      MarkedStatus  @default(PENDING)
  createdAt   DateTime      @default(now())

  sellListing     SellListing?
  rentListing     RentListing?
  exchangeListing ExchangeListing?
  comments        Comment[]
}

model SellListing {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  listingId String @unique @db.ObjectId
  listing  Listing @relation(fields: [listingId], references: [id])
  price    Float
}

model RentListing {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  listingId    String  @unique @db.ObjectId
  listing      Listing @relation(fields: [listingId], references: [id])
  pricePerHour Float
}

model ExchangeListing {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  listingId String  @unique @db.ObjectId
  listing   Listing @relation(fields: [listingId], references: [id])
}

model Comment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  content    String
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])
  fromEmail  String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

enum ListingType {
  SELL
  RENT
  EXCHANGE
}

enum MarkedStatus {
  PENDING
  SOLD
  RENTED
  EXCHANGED
}

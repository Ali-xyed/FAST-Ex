generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  to        String
  from      String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
